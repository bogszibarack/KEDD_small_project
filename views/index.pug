doctype html
html(lang="hu" x-data="{ sotetMod: false }" :data-bs-theme="sotetMod ? 'dark' : 'light'")
  head
    meta(charset="UTF-8")
    meta(name="viewport" content="width=device-width, initial-scale=1.0")
    title #{oldalCim}
    link(href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet")
    script(src="https://cdn.jsdelivr.net/npm/alpinejs@3.x.x/dist/cdn.min.js" defer)
  
  body
    //- Navbar + theme button
    nav.navbar.navbar-expand-lg.navbar-dark.bg-dark.mb-4
      div.container
        a.navbar-brand.fw-bold(href="/") KEDD Stúdió
        div.navbar-nav.me-auto
          a.nav-link.active(href="/") Mesetár
        
        div.d-flex.align-items-center.gap-3
          
          button.btn.btn-outline-light.btn-sm(@click="sotetMod = !sotetMod")
            span(x-text="sotetMod ? 'Világos mód' : 'Sötét mód'")
          
          a.btn.btn-success.fw-bold(href="/shop") 🛒 Irány a KEDDshop!

    div.container
      h1.text-center.mb-4.text-primary Üdvözöllek a KEDD Mini Mesetárban!
      p.text-center.text-muted Ez az oldal Node.js, Express, PUG, Bootstrap és Alpine.js használatával készült.

      //- Bootstrap rács
      div.row.g-4
        each mese in mesekListaja
          div.col-md-4
            div.card.h-100.shadow-sm(x-data="{ nyitva: false }")
              img.card-img-top(src=mese.kepUrl alt=mese.cim style="height: 200px; object-fit: cover;")
              div.card-body
                h5.card-title= mese.cim
                span.badge.bg-secondary.mb-2= "Korhatár: " + mese.korhatar
                button.btn.btn-outline-primary.w-100.mt-2(@click="nyitva = !nyitva") 
                  span(x-text="nyitva ? 'Leírás elrejtése' : 'Mutasd a leírást'")
                div.mt-3.p-3.bg-white.rounded.border(x-show="nyitva" x-transition)
                  p.card-text.small.text-dark.mb-0= mese.leiras

    footer.text-center.mt-5.py-3.text-muted.border-top
      p © 2026 Kókai Ádám - Készülés a KEDD Kft. interjúra