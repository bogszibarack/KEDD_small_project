doctype html
html(lang="hu" x-data="{ kosar: [], modalNyitva: false, sotetMod: false, get kosarDb() { return this.kosar.length }, get vegosszeg() { return this.kosar.reduce((sum, t) => sum + t.ar, 0) } }" :data-bs-theme="sotetMod ? 'dark' : 'light'")
  head
    meta(charset="UTF-8")
    meta(name="viewport" content="width=device-width, initial-scale=1.0")
    title #{oldalCim}
    link(href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet")
    script(src="https://cdn.jsdelivr.net/npm/alpinejs@3.x.x/dist/cdn.min.js" defer)
    style.
      .modal-backdrop-custom { position: fixed; top: 0; left: 0; width: 100vw; height: 100vh; z-index: 1040; background: rgba(0, 0, 0, 0.6); }
      .modal-custom { position: fixed; top: 20%; left: 50%; transform: translate(-50%, 0); z-index: 1050; display: block; }
      .video-item:hover { background-color: rgba(0,0,0,0.05); cursor: pointer; }
  
  body
    //- Webshop Navbár
    nav.navbar.navbar-expand-lg.navbar-dark.bg-dark.mb-4
      div.container
        a.navbar-brand.fw-bold(href="/") KEDD Stúdió
        div.navbar-nav.me-auto
          a.nav-link(href="/") Vissza a Mesetárba
        
        div.d-flex.align-items-center.gap-3
          //- Theme button
          button.btn.btn-outline-light.btn-sm(@click="sotetMod = !sotetMod")
            span(x-text="sotetMod ? 'Világos mód' : 'Sötét mód'")

          button.btn.btn-warning.fw-bold(@click="modalNyitva = true")
            | 🛒 Kosár: 
            span(x-text="kosarDb") 0
            |  db (
            span(x-text="vegosszeg") 0
            |  Ft) 

    div.container
      h1.text-center.mb-4.text-success Üdvözöllek a KEDDshop-ban!
      p.text-center.text-muted Válogass a hivatalos KEDD termékek közül. Live kosár funkcióval!

      //- Termékek rácsa
      div.row.g-4
        each termek in termekekListaja
          div.col-md-3
            div.card.h-100.shadow-sm
              img.card-img-top.bg-white(src=termek.kepUrl alt=termek.nev style="height: 180px; object-fit: contain;")
              div.card-body.d-flex.flex-column
                h5.card-title= termek.nev
                p.card-text.small.text-muted.flex-grow-1= termek.leiras
                div.mt-auto
                  h6.text-danger.fw-bold= termek.ar + " Ft"
                  button.btn.btn-success.w-100.mt-2(@click=`kosar.push({ nev: '${termek.nev}', ar: ${termek.ar} })`) Kosárba

      //- Elválasztó vonal
      hr.my-5

      //- Videók
      h2.fw-bold.mb-4 Videók
      
      //- Alpine.js alapértelmezett aktív videó ID beállítása az adatbázisból jövő első elemre
      div.row.g-4(x-data=`{ aktivVideoId: '${videokListaja[0] ? videokListaja[0].youtubeId : ""}' }`)
        
        //- (iframe)
        div.col-md-8
          div.ratio.ratio-16x9.shadow.rounded.overflow-hidden
            iframe(
              :src="'https://www.youtube.com/embed/' + aktivVideoId"
              title="YouTube video player"
              frameborder="0"
              allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
              allowfullscreen
            )

        //- (Playlist)
        div.col-md-4
          div.list-group.shadow-sm.overflow-y-auto(style="max-height: 450px;")
            each video in videokListaja
              div.list-group-item.video-item.d-flex.align-items-center.gap-2.p-2(
                @click=`aktivVideoId = '${video.youtubeId}'`
                :class=`aktivVideoId === '${video.youtubeId}' ? 'bg-body-secondary border-start border-4 border-danger' : ''`
              )
                //- borítókép
                img.rounded(src=`https://img.youtube.com/vi/${video.youtubeId}/0.jpg` style="width: 100px; height: 60px; object-fit: cover;")
                div
                  h6.mb-1.small.fw-bold.text-body(style="line-height: 1.2; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden;")= video.cim
                  span.badge.bg-secondary(style="font-size: 0.7rem;")= video.hossz

      //- Kosár
      div.text-dark(x-show="modalNyitva" x-transition)
        div.modal-backdrop-custom(@click="modalNyitva = false")
        div.modal-custom.card.shadow.w-100(style="max-width: 500px;")
          div.card-header.bg-warning.text-dark.d-flex.justify-content-between.align-items-center
            h5.mb-0.fw-bold 🛒 Kosarad tartalma
            button.btn-close(@click="modalNyitva = false")
          div.card-body
            template(x-if="kosarDb === 0")
              p.text-center.text-muted.my-3 A kosarad még teljesen üres.
            template(x-if="kosarDb > 0")
              ul.list-group.mb-3
                template(x-for="(tetel, index) in kosar" :key="index")
                  li.list-group-item.d-flex.justify-content-between.align-items-center
                    span(x-text="tetel.nev")
                    div
                      span.badge.bg-danger.rounded-pill.me-2(x-text="tetel.ar + ' Ft'")
                      button.btn.btn-sm.btn-outline-secondary(@click="nav.splice(index, 1)") ❌
            div.border-top.pt-3.d-flex.justify-content-between.fw-bold
              span Végösszeg:
              span.text-success(x-text="vegosszeg + ' Ft'")
          div.card-footer.d-flex.justify-content-end.gap-2
            button.btn.btn-secondary(@click="modalNyitva = false") Bezárás
            template(x-if="kosarDb > 0")
              button.btn.btn-success(@click="alert('Sikeres rendelés! Köszönjük, Ádám!'); kosar = []; modalNyitva = false;") Rendelés leadása

    footer.text-center.mt-5.py-3.text-muted.border-top
      p © 2026 Kókai Ádám - KEDDshop Live State Demo